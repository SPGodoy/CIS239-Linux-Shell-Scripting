#!/bin/bash

# Assignment 3 - Wildcards
# This script shows how wildcards can match files

echo "----------------------------------------"
echo "Assignment 3 - Wildcards"
echo "----------------------------------------"
echo ""

# Show all files
echo "All files in current directory:"
ls
echo ""

# Show all shell script files
echo "All shell scripts (*.sh):"
ls *.sh 2>/dev/null
echo ""

# Show all markdown files
echo "All markdown files (*.md):"
ls *.md 2>/dev/null
echo ""

# Show all text files
echo "All text files (*.txt):"
ls *.txt 2>/dev/null
echo ""

# Show files that start with a
echo "Files starting with 'a' (a*):"
ls a* 2>/dev/null
echo ""

# Show log files
echo "Files ending with '.log' (*.log):"
ls *.log 2>/dev/null
echo ""

# ? means one character
echo "Files with exactly one character before .sh (?.sh):"
ls ?.sh 2>/dev/null
echo ""

# ?? means two characters
echo "Files with exactly two characters before .sh (??.sh):"
ls ??.sh 2>/dev/null
echo ""

# Show files with test in the name
echo "Files with names containing 'test' (*test*):"
ls *test* 2>/dev/null
echo ""

# Loop through all shell scripts
echo "Loop through all shell scripts"
for file in *.sh
do
    if [ -e "$file" ]; then
        echo "Found shell script: $file"
    fi
done
echo ""

# Count file types
echo "Count files by type"
sh_count=$(ls *.sh 2>/dev/null | wc -l)
md_count=$(ls *.md 2>/dev/null | wc -l)
txt_count=$(ls *.txt 2>/dev/null | wc -l)

echo "Shell scripts: $sh_count"
echo "Markdown files: $md_count"
echo "Text files: $txt_count"
echo ""

echo "End of Assignment 3"
